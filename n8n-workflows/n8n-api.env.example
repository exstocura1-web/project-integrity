# Copy into C:\Exsto\.env (repo scripts load only this path).
# n8n Cloud: Settings → API → create key. For POST /api/v1/workflows/:id/execute,
# include scope workflow:execute if your Cloud instance exposes that endpoint;
# otherwise use webhooks or Manual run in the UI (405 = method/route not allowed for this key or instance).

N8N_CLOUD_URL=https://your-subdomain.app.n8n.cloud
N8N_CLOUD_API_KEY=paste_key_from_n8n_settings_api

# Optional webhooks (POST JSON {}) — c:\Exsto\n8n\invoke-n8n-webhook.ps1 or invoke-all-n8n-webhooks.ps1
# N8N_WEBHOOK_URL=https://your-subdomain.app.n8n.cloud/webhook/your-path
# N8N_WEBHOOK_WEEKLY_DIGEST=
# N8N_WEBHOOK_MONTHLY_REPORT=
# N8N_WEBHOOK_PROSPECT_INTEL=
# N8N_WEBHOOK_INVOICE_AGENT=
# N8N_WEBHOOK_SMARTPM_OUTREACH=
# After running: py -3 ensure_email_triage_test_webhook.py
# N8N_WEBHOOK_EMAIL_TRIAGE=https://your-subdomain.app.n8n.cloud/webhook/email-triage-test

# Optional (ui_live_test.py / Playwright only)
# N8N_CLOUD_EMAIL=
# N8N_CLOUD_PASSWORD=
