        "jsCode": "// ── CLIENT ROSTER ──────────────────────────────────────────\n// Add each active client here. SmartPM project IDs from your\n// SmartPM account dashboard under Settings > Projects.\n\nconst clients = [\n  {\n    name: 'TDI — Transmission Developers Inc',\n    project_id: 'SMARTPM_PROJECT_ID_TDI',\n    contact: 'Scott',\n    report_type: 'Owner Advisory',\n    contract_value: 'Retainer'\n  },\n  // Add additional clients here as you onboard them:\n  // { name: 'Client 2', project_id: 'SMARTPM_PROJECT_ID_2', ... }\n];\n\nconst month = new Date().toLocaleString('default', { month: 'long' });\nconst year = new Date().getFullYear();\n\nreturn clients.map(c => ({ json: { ...c, report_month: month, report_year: year, report_period: `${month} ${year}` } }));"
