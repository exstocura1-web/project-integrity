      ],
      "notes": "Checks invoice status three times per week — enough to stay on top without being annoying",
      "id": "eba15a4a-d648-452d-b203-adf9f0dbb566"
    },
    {
      "parameters": {
        "url": "https://api.honeybook.com/api/v2/invoices?status=sent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "name": "HoneyBook — Get Outstanding Invoices",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        480,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "48RGxhjkOn6nkAnH",
          "name": "Anthropic API Key"
        }
      },
      "notes": "HoneyBook API key found in: Account Settings > Integrations > API",
      "id": "464a96b8-7652-40d5-8d86-b23f01b8f2f0"
    },
    {
      "parameters": {
        "jsCode": "const invoices = $input.first().json.invoices || [];\nconst today = new Date();\n\nreturn invoices.map(inv => {\n  const sentDate = new Date(inv.sent_at);\n  const daysOutstanding = Math.floor((today - sentDate) / (1000 * 60 * 60 * 24));\n  \n  let status;\n  if (daysOutstanding < 7)  status = 'CURRENT';\n  else if (daysOutstanding < 14) status = 'FOLLOW_UP';\n  else if (daysOutstanding < 30) status = 'OVERDUE';\n  else status = 'ESCALATE';\n  \n  return {\n    json: {\n      invoice_id: inv.id,\n      client_name: inv.client_name,\n      amount: inv.amount,\n      sent_date: inv.sent_at,\n      days_outstanding: daysOutstanding,\n      due_date: inv.due_date,\n      status,\n      invoice_number: inv.invoice_number\n    }\n  };\n}).filter(i => i.json.status !== 'CURRENT');"
      },
      "name": "Calculate Days Outstanding",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        300
      ],
      "id": "59ba5a12-7f93-427a-b3a4-c9e217fe9535"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "esc1",
              "leftValue": "={{ $json.status }}",
              "rightValue": "ESCALATE",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "name": "Is ESCALATE (30+ days)?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        960,
        300
      ],
      "id": "1ba39b47-b159-4b57-be67-c3726c46839c"
    },
    {
      "parameters": {
        "model": "claude-haiku-3-20250307",
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Write a professional payment follow-up message from Michael Craig at Exsto Cura Consilium.\n\nINVOICE DETAILS:\n- Client: {{ $json.client_name }}\n- Invoice #: {{ $json.invoice_number }}\n- Amount: ${{ $json.amount }}\n- Days Outstanding: {{ $json.days_outstanding }}\n- Status: {{ $json.status }}\n\nTone guidance by status:\n- FOLLOW_UP (7-14 days): Friendly, light touch, assume oversight\n- OVERDUE (14-30 days): Professional, clear, note the due date\n- ESCALATE (30+ days): Firm, professional, reference contract terms\n\nWrite ONLY the email body. No subject line. 3-5 sentences maximum. Do not be aggressive. Maintain the professional senior consultant relationship. Sign off as Michael Craig, Exsto Cura Consilium."
            }
          ]
        },
        "options": {
          "maxTokens": 300
        }
      },
      "name": "Claude — Draft Follow-up Message",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [
        960,
        500
      ],
      "credentials": {
        "anthropicApi": {
          "id": "u85U62dgbcEwpdkT",
          "name": "Anthropic account"
        }
      },
      "id": "8e663135-5e4a-4f98-81d5-927ee8220a34"
    },
    {
      "parameters": {
        "sendTo": "mcraig@exstocura.com",
        "subject": "=🔴 ESCALATE — Invoice #{{ $json.invoice_number }} | {{ $json.client_name }} | ${{ $json.amount }} | {{ $json.days_outstanding }} Days",
        "emailType": "html",
        "message": "=<div style='font-family: Georgia, serif; max-width: 600px; padding: 20px; background: #0d0d0d; color: #e8e4dc;'><h2 style='color: #e07070; border-bottom: 1px solid #333; padding-bottom: 10px;'>🔴 Invoice Escalation Alert</h2><p><strong>Client:</strong> {{ $json.client_name }}</p><p><strong>Invoice:</strong> #{{ $json.invoice_number }}</p><p><strong>Amount:</strong> ${{ $json.amount }}</p><p><strong>Days Outstanding:</strong> {{ $json.days_outstanding }} days</p><p><strong>Status:</strong> {{ $json.status }}</p><hr style='border-color: #333;'/><p style='color: #e07070;'>This invoice is 30+ days outstanding. Review your contract terms and consider direct contact with the client.</p><p>Log into HoneyBook to take action.</p><hr style='border-color: #333;'/><p style='color: #666; font-size: 12px;'>Exsto Cura Invoice Agent</p></div>",
        "options": {}
