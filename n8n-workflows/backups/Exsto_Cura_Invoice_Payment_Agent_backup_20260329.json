        "emailType": "html",
        "message": "=<div style='font-family: Georgia, serif; max-width: 600px; padding: 20px; background: #0d0d0d; color: #e8e4dc;'><h2 style='color: #c9a96e; border-bottom: 1px solid #333; padding-bottom: 10px;'>💛 Invoice Follow-up Draft</h2><p><strong>Client:</strong> {{ $('Calculate Days Outstanding').first().json.client_name }}</p><p><strong>Invoice:</strong> #{{ $('Calculate Days Outstanding').first().json.invoice_number }}</p><p><strong>Amount:</strong> ${{ $('Calculate Days Outstanding').first().json.amount }}</p><p><strong>Days Outstanding:</strong> {{ $('Calculate Days Outstanding').first().json.days_outstanding }} days</p><hr style='border-color: #333;'/><h3 style='color: #c9a96e;'>Suggested Follow-up Message</h3><div style='background: #1a1a1a; padding: 15px; border-left: 3px solid #c9a96e; white-space: pre-wrap;'>{{ $json.text }}</div><hr style='border-color: #333;'/><p style='color: #999; font-size: 12px;'>Review, edit if needed, and send from HoneyBook or directly. Exsto Cura Invoice Agent.</p></div>",
