# ANTHROPIC_API_KEY: Required for Claude AI — replaces GEMINI_API_KEY.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Frontend runtime URLs (used by Vite app in production)
# Example: https://your-api.railway.app
VITE_API_BASE_URL=""
VITE_SOCKET_URL=""

# APP_URL: The public URL where this app is hosted.
# For local dev: http://localhost:3000
# For Railway production: https://your-app.railway.app
APP_URL="http://localhost:3000"

# FRONTEND_URL: Allowed browser origin for CORS (Vercel URL)
# Example: https://your-frontend.vercel.app
FRONTEND_URL=""

# Oracle Primavera Cloud Configuration
OPC_API_URL="https://primavera.oraclecloud.com/api"
OPC_CLIENT_ID=""
OPC_CLIENT_SECRET=""

# Acumen Fuse / Deltek Configuration
ACUMEN_API_KEY=""

# OneDrive / Microsoft Graph Configuration
# Register an app at https://portal.azure.com → App registrations
ONEDRIVE_CLIENT_ID=""
ONEDRIVE_CLIENT_SECRET=""
ONEDRIVE_TENANT_ID="common"

# SmartPM Configuration
# For trial accounts: use file export + parseSmartPMExport() in claudeService.ts
SMARTPM_API_KEY=""

# Firebase Admin SDK (server-side — for Firestore writes from server.ts)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
