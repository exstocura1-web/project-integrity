# ANTHROPIC_API_KEY: Required for Claude on server /api/ai/* (see docs/MODEL-GOVERNANCE.md)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# NODE_ENV: production on Railway; omit or development locally
# PORT: Railway sets automatically; local default 3000

# Frontend runtime URLs (Vite — public, safe in browser bundle)
# Split deploy: point to Railway API host (same value for both in typical setups)
# Example: https://project-integrity.up.railway.app
VITE_API_BASE_URL=""
VITE_SOCKET_URL=""

# APP_URL: Public URL of the Node API (same host as dev, or Railway URL)
APP_URL="http://localhost:3000"

# FRONTEND_URL: Primary browser origin for CORS (Railway also allows projectintegrity.cloud + www)
# Example: https://projectintegrity.cloud
FRONTEND_URL=""

# Oracle Primavera Cloud Configuration
OPC_API_URL="https://primavera.oraclecloud.com/api"
OPC_CLIENT_ID=""
OPC_CLIENT_SECRET=""

# Acumen Fuse / Deltek Configuration
ACUMEN_API_KEY=""

# OneDrive / Microsoft Graph Configuration
# Register an app at https://portal.azure.com → App registrations
ONEDRIVE_CLIENT_ID=""
ONEDRIVE_CLIENT_SECRET=""
ONEDRIVE_TENANT_ID="common"

# SmartPM Configuration
# For trial accounts: use file export + parseSmartPMExport() in claudeService.ts
SMARTPM_API_KEY=""

# Firebase Admin SDK (server-side — Firestore + Storage uploads from server.ts)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Optional: default bucket is <FIREBASE_PROJECT_ID>.appspot.com
FIREBASE_STORAGE_BUCKET=""

# Client Firebase web SDK config lives in firebase-applet-config.json (not .env) unless you refactor src/firebase.ts.

# GEMINI_API_KEY: optional; src/services/geminiService.ts is not wired to Express /api/ai/* routes
